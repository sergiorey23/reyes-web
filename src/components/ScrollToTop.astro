---
---
<button id="scroll-to-top" class="fixed bottom-6 right-6 z-50 p-3 rounded-full shadow-xl bg-brand-green text-white opacity-0 translate-y-10 pointer-events-none transition-all duration-300 hover:bg-brand-green-dark hover:-translate-y-1 focus:outline-none" aria-label="Volver arriba">
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
  </svg>
</button>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const scrollBtn = document.getElementById('scroll-to-top');

    const toggleVisibility = () => {
      if (window.scrollY > 400) {
        scrollBtn?.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
        scrollBtn?.classList.add('opacity-100', 'translate-y-0', 'cursor-pointer');
      } else {
        scrollBtn?.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
        scrollBtn?.classList.remove('opacity-100', 'translate-y-0', 'cursor-pointer');
      }
    };

    window.addEventListener('scroll', toggleVisibility);
    
    // Check initial position in case the user refreshes midway down the page
    toggleVisibility();

    scrollBtn?.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  });
</script>