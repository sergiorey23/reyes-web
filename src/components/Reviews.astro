---
import { sanityClient } from "sanity:client";

interface Review {
  rating: number;
  title: string;
  content: string;
  name?: string;
  date?: string;
}

// Obtenemos todas las reseñas aprobadas desde Sanity
const allReviews: Review[] = await sanityClient.fetch(`*[_type == "review" && approved == true] | order(date desc)`);

// Helper to render stars
const renderStars = (rating: number) => {
  return Array.from({ length: 5 })
    .map((_, i) =>
      i < rating
        ? '<svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'
        : '<svg class="w-5 h-5 text-gray-300 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'
    )
    .join("");
};

// Calculations for summary
const totalReviews = allReviews.length;
const averageRatingNum = totalReviews > 0 ? allReviews.reduce((acc, review) => acc + (review.rating || 0), 0) / totalReviews : 0;
const averageRating = averageRatingNum.toFixed(1).replace(".", ",");

const ratingCounts = { 5: 0, 4: 0, 3: 0, 2: 0, 1: 0 };
allReviews.forEach((r) => {
  const rating = r.rating || 0;
  if (rating >= 1 && rating <= 5) {
    ratingCounts[rating as keyof typeof ratingCounts]++;
  }
});

const ratingPercentages = {
  5: totalReviews > 0 ? Math.round((ratingCounts[5] / totalReviews) * 100) : 0,
  4: totalReviews > 0 ? Math.round((ratingCounts[4] / totalReviews) * 100) : 0,
  3: totalReviews > 0 ? Math.round((ratingCounts[3] / totalReviews) * 100) : 0,
  2: totalReviews > 0 ? Math.round((ratingCounts[2] / totalReviews) * 100) : 0,
  1: totalReviews > 0 ? Math.round((ratingCounts[1] / totalReviews) * 100) : 0
};

const labels: Record<number, string> = {
  5: "Excelente",
  4: "Muy buena",
  3: "Media",
  2: "Mala",
  1: "Muy mala"
};
---

<section class="py-16 bg-brand-light transition-colors duration-300 dark:bg-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-serif text-brand-green-dark dark:text-brand-green-light text-center mb-12">Lo que dicen mis pacientes</h2>

    <!-- Summary -->
    <div class="max-w-lg mx-auto bg-gray-50 dark:bg-gray-900 p-5 sm:p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 mb-12">
      <div class="flex items-center gap-3 mb-1">
        <span class="text-3xl font-bold text-gray-900 dark:text-gray-100">{averageRating}</span>
        <div class="flex" set:html={renderStars(Math.round(averageRatingNum))} />
      </div>
      <p class="text-gray-600 dark:text-gray-400 mb-4 text-sm font-medium">
        {averageRating} de 5 estrellas (basado en {totalReviews} reseña{totalReviews !== 1 ? "s" : ""})
      </p>

      <div class="space-y-2">
        {
          [5, 4, 3, 2, 1].map((star) => (
            <div class="flex items-center gap-3 text-xs sm:text-sm">
              <div class="w-20 sm:w-24 shrink-0 text-gray-700  dark:text-gray-300 font-medium">{labels[star as keyof typeof labels]}</div>
              <div class="grow h-2.5 bg-gray-200 dark:bg-gray-500 rounded-sm overflow-hidden">
                <div
                  class="h-full bg-yellow-400 rounded-sm transition-all duration-1000 ease-out"
                  style={`width: ${ratingPercentages[star as keyof typeof ratingPercentages]}%`}
                />
              </div>
              <div class="w-10 sm:w-12 shrink-0 text-right text-gray-600  dark:text-gray-400 font-medium">
                {ratingPercentages[star as keyof typeof ratingPercentages]}%
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 mb-8" id="reviews-grid">
      {
        allReviews.map((review, index) => (
          <div
            class={`bg-gray-50 dark:bg-gray-900 p-6 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 review-card ${index >= 3 ? "hidden" : ""}`}
          >
            <div class="flex items-center gap-3 mb-4">
              <div class="flex items-center" set:html={renderStars(review.rating)} />
              {review.date && (
                <span class="text-sm text-gray-500 dark:text-gray-400 font-medium border-l border-gray-300 dark:border-gray-600 pl-3">
                  {new Date(review.date).toLocaleDateString("es-ES")}
                </span>
              )}
            </div>
            <h3 class="font-bold text-lg mb-2 text-gray-800 dark:text-gray-200">{review.title}</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-4 italic">{review.content}</p>
            <div class="text-sm text-gray-500 dark:text-gray-400 font-medium">- {review.name || "Anónimo"}</div>
          </div>
        ))
      }
    </div>

    {
      allReviews.length > 3 && (
        <div class="text-center mb-12">
          <button
            id="load-more-reviews"
            type="button"
            class="  transition duration-300 border border-brand-green dark:border-brand-green-light text-brand-green dark:text-brand-green-light font-medium py-2 px-6 rounded-md hover:bg-brand-green dark:hover:bg-brand-green-light hover:text-white dark:hover:text-black cursor-pointer"
          >
            Cargar más reseñas
          </button>
        </div>
      )
    }

    <!-- Review Form -->
    <div
      class="max-w-2xl mx-auto bg-white dark:bg-gray-900 transition-colors duration-300 p-8 rounded-xl shadow-md border border-gray-100 dark:border-gray-700"
    >
      <h3 class="text-2xl font-serif mb-6 text-center">Deja tu reseña</h3>
      <form action="/api/reviews" method="POST" class="space-y-4" id="review-form">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Puntuación</label>
          <div class="flex space-x-1" id="star-rating">
            <svg
              class="w-8 h-8 text-gray-300 cursor-pointer star transition-colors hover:text-yellow-400"
              data-value="1"
              fill="currentColor"
              viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path>
            </svg>
            <svg
              class="w-8 h-8 text-gray-300 cursor-pointer star transition-colors hover:text-yellow-400"
              data-value="2"
              fill="currentColor"
              viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path>
            </svg>
            <svg
              class="w-8 h-8 text-gray-300 cursor-pointer star transition-colors hover:text-yellow-400"
              data-value="3"
              fill="currentColor"
              viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path>
            </svg>
            <svg
              class="w-8 h-8 text-gray-300 cursor-pointer star transition-colors hover:text-yellow-400"
              data-value="4"
              fill="currentColor"
              viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path>
            </svg>
            <svg
              class="w-8 h-8 text-gray-300 cursor-pointer star transition-colors hover:text-yellow-400"
              data-value="5"
              fill="currentColor"
              viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path>
            </svg>
          </div>
          <input type="hidden" name="rating" id="rating-input" value="0" />
          <p id="rating-error" class="text-red-500 text-sm mt-1 hidden">Por favor, selecciona una puntuación.</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Título</label>
          <input
            type="text"
            name="title"
            required
            class="w-full bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 rounded-md shadow-sm p-2 border focus:ring-brand-blue focus:border-brand-blue"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Reseña</label>
          <textarea
            name="content"
            rows="4"
            required
            class="w-full bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 rounded-md shadow-sm p-2 border focus:ring-brand-blue focus:border-brand-blue"
          ></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nombre (Opcional)</label>
          <input
            type="text"
            name="name"
            class="w-full bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 rounded-md shadow-sm p-2 border focus:ring-brand-blue focus:border-brand-blue"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-amber-500 dark:bg-amber-600 hover:bg-amber-600 dark:hover:bg-amber-700 text-white font-medium py-3 px-4 rounded-md cursor-pointer transition"
        >
          Enviar reseña
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  // Script para gestionar la carga de más reseñas
  const loadMoreBtn = document.getElementById("load-more-reviews");
  if (loadMoreBtn) {
    let visibleCount = 3;
    const reviewCards = document.querySelectorAll(".review-card");

    loadMoreBtn.addEventListener("click", () => {
      const nextCount = visibleCount + 3;
      for (let i = visibleCount; i < nextCount && i < reviewCards.length; i++) {
        reviewCards[i].classList.remove("hidden");
      }
      visibleCount = nextCount;

      if (visibleCount >= reviewCards.length) {
        loadMoreBtn.style.display = "none";
      }
    });
  }

  // Script para gestionar las estrellas interactivas
  const stars = document.querySelectorAll(".star");
  const ratingInput = document.getElementById("rating-input") as HTMLInputElement;
  const ratingError = document.getElementById("rating-error");
  const form = document.getElementById("review-form") as HTMLFormElement;

  stars.forEach((star) => {
    star.addEventListener("click", (e) => {
      const target = e.currentTarget as HTMLElement;
      const value = parseInt(target.getAttribute("data-value") || "0", 10);
      ratingInput.value = value.toString();
      ratingError?.classList.add("hidden");

      stars.forEach((s) => {
        const starValue = parseInt(s.getAttribute("data-value") || "0", 10);
        if (starValue <= value) {
          s.classList.remove("text-gray-300");
          s.classList.add("text-yellow-400");
        } else {
          s.classList.add("text-gray-300");
          s.classList.remove("text-yellow-400");
        }
      });
    });

    star.addEventListener("mouseover", (e) => {
      const target = e.currentTarget as HTMLElement;
      const value = parseInt(target.getAttribute("data-value") || "0", 10);
      stars.forEach((s) => {
        const starValue = parseInt(s.getAttribute("data-value") || "0", 10);
        if (starValue <= value) {
          s.classList.add("text-yellow-300");
        } else {
          s.classList.remove("text-yellow-300");
        }
      });
    });

    star.addEventListener("mouseout", () => {
      stars.forEach((s) => s.classList.remove("text-yellow-300"));
    });
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (ratingInput.value === "0") {
      ratingError?.classList.remove("hidden");
      return;
    }

    const formData = new FormData(form);

    try {
      const response = await fetch("/api/reviews", {
        method: "POST",
        body: formData
      });

      if (response.ok) {
        alert("¡Gracias por tu reseña! " + (ratingInput.value === "5" ? "Se ha publicado correctamente." : "Ha sido enviada y está pendiente de moderación."));
        form.reset();
        // Reset stars
        ratingInput.value = "0";
        stars.forEach((s) => {
          s.classList.add("text-gray-300");
          s.classList.remove("text-yellow-400");
        });
      } else {
        alert("Hubo un error al enviar la reseña. Inténtalo de nuevo.");
      }
    } catch (error) {
      alert("Error de conexión.");
    }
  });
</script>
