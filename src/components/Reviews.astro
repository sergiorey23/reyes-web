---
import { sanityClient } from "sanity:client";

// Obtenemos las últimas 3 reseñas aprobadas desde Sanity
const displayReviews = await sanityClient.fetch(`*[_type == "review" && approved == true] | order(date desc)[0...3]`);

// Helper to render stars
const renderStars = (rating: number) => {
  return Array.from({ length: 5 }).map((_, i) => (
    i < rating 
      ? '<svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'
      : '<svg class="w-5 h-5 text-gray-300 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'
  )).join('');
};
---

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-serif text-brand-blue-dark text-center mb-12">Lo que dicen mis pacientes</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      {displayReviews.map((review) => (
        <div class="bg-gray-50 p-6 rounded-lg shadow-sm border border-gray-100">
          <div class="flex items-center mb-4" set:html={renderStars(review.rating)} />
          <h3 class="font-bold text-lg mb-2 text-gray-800">{review.title}</h3>
          <p class="text-gray-600 mb-4 italic">"{review.content}"</p>
          <div class="text-sm text-gray-500 font-medium">- {review.name || 'Anónimo'}</div>
        </div>
      ))}
    </div>

    <!-- Review Form -->
    <div class="max-w-2xl mx-auto bg-brand-light p-8 rounded-xl shadow-md border border-gray-100">
      <h3 class="text-2xl font-serif text-brand-blue mb-6 text-center">Deja tu reseña</h3>
      <form action="/api/reviews" method="POST" class="space-y-4" id="review-form">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Puntuación</label>
          <div class="flex space-x-1" id="star-rating">
            <svg class="w-8 h-8 text-gray-300 cursor-pointer star transition-colors hover:text-yellow-400" data-value="1" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-8 h-8 text-gray-300 cursor-pointer star transition-colors hover:text-yellow-400" data-value="2" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-8 h-8 text-gray-300 cursor-pointer star transition-colors hover:text-yellow-400" data-value="3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-8 h-8 text-gray-300 cursor-pointer star transition-colors hover:text-yellow-400" data-value="4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-8 h-8 text-gray-300 cursor-pointer star transition-colors hover:text-yellow-400" data-value="5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <input type="hidden" name="rating" id="rating-input" value="0">
          <p id="rating-error" class="text-red-500 text-sm mt-1 hidden">Por favor, selecciona una puntuación.</p>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Título</label>
          <input type="text" name="title" required class="w-full border-gray-300 rounded-md shadow-sm p-2 border focus:ring-brand-blue focus:border-brand-blue">
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Reseña</label>
          <textarea name="content" rows="4" required class="w-full border-gray-300 rounded-md shadow-sm p-2 border focus:ring-brand-blue focus:border-brand-blue"></textarea>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Nombre (Opcional)</label>
          <input type="text" name="name" class="w-full border-gray-300 rounded-md shadow-sm p-2 border focus:ring-brand-blue focus:border-brand-blue">
        </div>
        
        <button type="submit" class="w-full bg-brand-blue text-white font-medium py-3 px-4 rounded-md hover:bg-brand-blue-dark transition">
          Enviar reseña
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  // Script para gestionar las estrellas interactivas
  const stars = document.querySelectorAll('.star');
  const ratingInput = document.getElementById('rating-input') as HTMLInputElement;
  const ratingError = document.getElementById('rating-error');
  const form = document.getElementById('review-form') as HTMLFormElement;

  stars.forEach(star => {
    star.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLElement;
      const value = parseInt(target.getAttribute('data-value') || '0', 10);
      ratingInput.value = value.toString();
      ratingError?.classList.add('hidden');
      
      stars.forEach(s => {
        const starValue = parseInt(s.getAttribute('data-value') || '0', 10);
        if (starValue <= value) {
          s.classList.remove('text-gray-300');
          s.classList.add('text-yellow-400');
        } else {
          s.classList.add('text-gray-300');
          s.classList.remove('text-yellow-400');
        }
      });
    });

    star.addEventListener('mouseover', (e) => {
      const target = e.currentTarget as HTMLElement;
      const value = parseInt(target.getAttribute('data-value') || '0', 10);
      stars.forEach(s => {
        const starValue = parseInt(s.getAttribute('data-value') || '0', 10);
        if (starValue <= value) {
          s.classList.add('text-yellow-300');
        } else {
          s.classList.remove('text-yellow-300');
        }
      });
    });

    star.addEventListener('mouseout', () => {
      stars.forEach(s => s.classList.remove('text-yellow-300'));
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (ratingInput.value === '0') {
      ratingError?.classList.remove('hidden');
      return;
    }
    
    const formData = new FormData(form);
    
    try {
      const response = await fetch('/api/reviews', {
        method: 'POST',
        body: formData
      });
      
      if (response.ok) {
        alert('¡Gracias por tu reseña! ' + (ratingInput.value === '5' ? 'Se ha publicado correctamente.' : 'Ha sido enviada y está pendiente de moderación.'));
        form.reset();
        // Reset stars
        ratingInput.value = '0';
        stars.forEach(s => {
          s.classList.add('text-gray-300');
          s.classList.remove('text-yellow-400');
        });
      } else {
        alert('Hubo un error al enviar la reseña. Inténtalo de nuevo.');
      }
    } catch (error) {
      alert('Error de conexión.');
    }
  });
</script>
