---

---

<div class="fixed bottom-6 left-6 z-50 font-sans">
  <!-- Ventana de Chat (Oculta por defecto) -->
  <div id="wa-chat" class="hidden mb-4 w-72 bg-white rounded-xl shadow-2xl overflow-hidden transform transition-all origin-bottom-left">
    <div class="bg-[#075E54] text-white px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center overflow-hidden">
          <img src="https://reyesgarciamiro.com/wp-content/uploads/2020/07/Reyes.jpg" alt="Reyes" class="w-full h-full object-cover" />
        </div>
        <div>
          <div class="font-bold text-sm">Reyes García Miró</div>
          <div class="text-xs text-green-100">En línea</div>
        </div>
      </div>
      <button id="wa-close" class="text-white hover:text-gray-200 cursor-pointer">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg
        >
      </button>
    </div>

    <div class="p-4 bg-[#E5DDD5] h-32 overflow-y-auto">
      <div class="bg-white text-gray-800 text-sm p-2 rounded-lg rounded-tl-none inline-block shadow-sm">¡Hola! 👋 ¿En qué te puedo ayudar?</div>
    </div>

    <div class="p-3 bg-white border-t border-gray-100 flex gap-2">
      <input
        type="text"
        id="wa-input"
        placeholder="Escribe tu mensaje..."
        class="flex-1 text-sm outline-none border border-gray-200 rounded-full px-3 py-2 focus:border-green-500"
      />
      <button id="wa-send" class="bg-[#128C7E] text-white p-2 rounded-full hover:bg-[#075E54] transition cursor-pointer">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" style="transform: translateX(1px);"
          ><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path></svg
        >
      </button>
    </div>
  </div>

  <!-- Botón Flotante -->
  <button
    id="wa-btn"
    class="bg-[#25D366] text-white w-14 h-14 rounded-full shadow-xl flex items-center justify-center hover:scale-110 transition-transform focus:outline-none cursor-pointer"
  >
    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
      ></path>
    </svg>
  </button>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const waBtn = document.getElementById("wa-btn");
    const waChat = document.getElementById("wa-chat");
    const waClose = document.getElementById("wa-close");
    const waSend = document.getElementById("wa-send");
    const waInput = document.getElementById("wa-input") as HTMLInputElement;
    const phoneNumber = "34630893355"; // Número de teléfono de Reyes

    // Toggle Chat
    waBtn?.addEventListener("click", () => {
      waChat?.classList.toggle("hidden");
      if (!waChat?.classList.contains("hidden")) {
        waInput?.focus();
      }
    });

    waClose?.addEventListener("click", () => {
      waChat?.classList.add("hidden");
    });

    // Send Message
    const sendMessage = () => {
      const text = waInput?.value.trim();
      if (text) {
        const url = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(text)}`;
        window.open(url, "_blank");
        waInput.value = "";
        waChat?.classList.add("hidden");
      }
    };

    waSend?.addEventListener("click", sendMessage);
    waInput?.addEventListener("keypress", (e) => {
      if (e.key === "Enter") sendMessage();
    });
  });
</script>
