---
import Layout from "../../layouts/Layout.astro";
import { sanityClient } from "sanity:client";
import { urlFor } from "../../utils/sanity.js";
import { PortableText } from "astro-portabletext";

const { slug } = Astro.params;

// Al tener SSR activado (`output: "server"`), esto se ejecutará bajo demanda para cada artículo
const post = await sanityClient.fetch(`*[_type == "post" && slug.current == $slug][0]`, { slug });

if (!post) {
  return Astro.redirect("/404");
}

const publishedDate = new Date(post.publishedAt).toLocaleDateString("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric"
});
---

<Layout title={`${post.title} | Blog de Psicología`}>
  <article class="py-16 bg-white min-h-[60vh]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <a href="/blog" class="inline-flex items-center text-brand-green hover:text-brand-green-dark mb-6 transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
          >
          Volver al blog
        </a>
        <time class="text-sm font-medium text-gray-500 uppercase tracking-wider block mb-4">{publishedDate}</time>
        <h1 class="text-4xl md:text-5xl font-serif text-gray-900 mb-6 leading-tight">{post.title}</h1>
      </div>

      {
        post.mainImage?.asset && (
          <div class="mb-12 rounded-2xl overflow-hidden shadow-sm bg-gray-50 flex justify-center max-w-2xl mx-auto">
            <img src={urlFor(post.mainImage).width(1200).url()} alt={post.title} class="max-w-full h-auto  max-h-150" />
          </div>
        )
      }

      <div class="prose prose-lg prose-blue max-w-none mx-auto prose-img:rounded-xl prose-headings:font-serif">
        <PortableText value={post.body} />
      </div>
    </div>
  </article>
</Layout>
